<!DOCTYPE html>
<html lang="ro">
<head>
    <%- include("../fragmente/head") %>     
    <script type="text/javascript" src="/resurse/js/produse.js"></script>
    <script type="text/javascript" src="/resurse/js/produse-cos.js"></script>
</head>
<body>

<%- include("../fragmente/header") %>

<main>
    <!-- Filtrare după Nume -->
    <label> Nume plantă: <input type="text" id="inp-nume"></label>
    
    <!-- Filtrare după Înălțime (în loc de calorii) -->
    <div> Înălțime (cm):
        <p><label>Mici (0 - 30 cm)
            <input id="i_rad1" name="gr_rad" value="0:30" type="radio"/>
        </label></p>
        <p><label>Medii (30 - 70 cm)
            <input id="i_rad2" name="gr_rad" value="30:70" type="radio"/>
        </label></p>
        <p><label>Mari (70+ cm)
            <input id="i_rad3" name="gr_rad" value="70:1000000" type="radio"/>
        </label></p>
        <p><label>Toate
            <input id="i_rad4" checked name="gr_rad" value="toate" type="radio"/>
        </label></p>
    </div>

    <!-- Filtrare după Preț (Am ajustat max la 400 pentru Pink Princess) -->
    <label> Preț minim: <input type="range" id="inp-pret" value="0" min="0" max="400"> <span id="infoRange">(0)</span></label>
    
    <label>Categorie:
        <select id="inp-categorie">
            <option id="sel-toate" selected value="toate">toate</option>
            <% for (let opt of locals.optiuni) { %>
                <option value="<%- opt.unnest %>"><%- opt.unnest %> </option>
            <% } %>
        </select>
    </label>

    <p>
        <button id="filtrare">Filtrează</button> 
        <button id="resetare">Resetează</button><br/>
        <button id="sortCrescNume">Sortează crescător după preț și nume</button>
        <button id="sortDescrescNume">Sortează descrescător după preț și nume</button>
    </p>
  
    <p id="p-suma">Apăsați Alt+"c" pentru suma prețurilor plantelor afișate. </p>

    <section id="produse">
        <h2>Plante disponibile</h2>
        <div class="grid-produse">
            <% for( let prod of locals.produse) { %>
                <article class="produs">
                    <h3 class="nume">Nume: <a href="/produs/<%-prod.id %>" ><span class="val-nume"><%- prod.nume%></span></a></h3>
                    
                    <div class="info-prod">
                        <p class="pret">Preț: <span class="val-pret"><%- prod.pret%></span> RON</p>
                        <!-- Folosim val-calorii ca ID in JS pentru inaltime ca sa nu modifici tot fisierul .js -->
                        <p class="inaltime">Înălțime: <span class="val-calorii"><%- prod.inaltime_cm%></span> cm</p>
                        <p class="prezentare">Prezentare: <span class="val-prezentare"><%- prod.prezentare%></span></p>
                    </div>
                    
                    <p class="categorie">Categorie: <span class="val-categorie"><%- prod.categorie%></span></p>
                    
                    <!-- Afișăm dacă este toxică sau nu -->
                    <p class="toxic">Toxic animale: <span><%- prod.toxic_animale ? "DA" : "NU" %></span></p>

                    <figure>
                        <a href="/produs/<%-prod.id %>" >
                            <img src="/resurse/imagini/produse/<%- prod.imagine %>" style="width:50%;height:auto;" alt="[imagine <%- prod.nume %>]" />
                        </a>
                    </figure>

                    <label class="selecteaza-cos">
                        Selectează:<br/>
                        <input type="checkbox" class="select-cos" value="<%-prod.id %>" autocomplete="off">
                    </label>
                </article>
            <% }%>
        </div>
    </section>
</main>

<%- include("../fragmente/footer") %>
</body>
</html>